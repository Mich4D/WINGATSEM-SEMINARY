# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# STRIPE_SECRET_KEY: Required for processing payments.
# Users configure this via the Secrets panel in the AI Studio UI.
STRIPE_SECRET_KEY="YOUR_STRIPE_SECRET_KEY"

# ADMIN_BOOTSTRAP_SECRET: Optional. A secret string you can use to bootstrap your first admin account.
ADMIN_BOOTSTRAP_SECRET="your-secret-here"

# SMTP Configuration for Email Notifications
# Required for sending admission emails. 
# IMPORTANT FOR GMAIL: You MUST use a 16-character 'App Password', NOT your login password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="wingatsem@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx" # MUST BE 16 CHARACTERS FOR GMAIL
SMTP_FROM="wingatsem@gmail.com"
SMTP_SENDER_NAME="Winning Gate Seminary"

# Supabase Configuration
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
